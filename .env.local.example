# ── Autenticação do app ──────────────────────────────────────────────────────
# Senha padrão que todos os colaboradores usam para entrar
SENHA_APP=suasenha123

# ── Google Sheets ─────────────────────────────────────────────────────────────
# ID da planilha operacional (da URL: /spreadsheets/d/ID_AQUI/edit)
GOOGLE_SPREADSHEET_ID=1G18phF2zzk_Nfj1-7oXIfR-IhaDeOsEi

# Letra da coluna onde os valores serão escritos (ex: F, G, H...)
# Defina conforme a coluna de entrada da semana/mês atual na planilha
COLUNA_ENTRADA=F

# Credenciais da Service Account do Google Cloud (JSON em uma linha só)
# Passos para obter:
#   1. Google Cloud Console → IAM → Contas de serviço → Criar conta
#   2. Gerar chave JSON → baixar o arquivo
#   3. Compartilhar a planilha com o e-mail da service account (permissão de Editor)
#   4. Copiar o conteúdo do JSON aqui (todo em UMA linha, sem quebras)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
